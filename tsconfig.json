{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "noEmit": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "jsx": "react-jsx"
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "vendor",
        "public/build",
        "public/hot",
        "storage",
        "bootstrap/cache",
        "resources/js/actions/**",
        "resources/js/routes/**",
        "resources/js/wayfinder/**",
        "resources/js/components/admin-resource/_archive_old/**"
    ]
}
